# =====================================================================================
# Biến môi trường cho Kinderland Microservices.
# Copy file này thành `.env` rồi điền giá trị thật (KHÔNG commit .env lên git).
#
# Các service tự nạp .env qua: spring.config.import=optional:file:.env[.properties]
# Giá trị có [mặc định] ở dưới thì để trống cũng chạy; giá trị (BẮT BUỘC) phải điền.
# =====================================================================================

# ----- JWT (auth-service ký token; api-gateway dùng CÙNG secret để verify) -----
# BẮT BUỘC. Phải đủ dài cho HMAC-SHA (khuyến nghị >= 32 ký tự / 256-bit).
JWT_SECRET=ThisIsADevSecretChangeMeToALongRandomValue123456
# [mặc định 3600000 = 1 giờ] hạn access token (ms)
JWT_EXPIRATION=3600000
# [mặc định 604800000 = 7 ngày] hạn refresh token (ms)
JWT_REFRESH_EXPIRATION=604800000

# ----- PostgreSQL (mỗi service có DB riêng, dùng chung user/pass) -----
# [mặc định postgres / 123456]
DB_USERNAME=postgres
DB_PASSWORD=123456

# ----- Redis (token blacklist, dùng chung giữa auth-service & api-gateway) -----
# [mặc định localhost / 6379]. Chạy full trong Docker thì đặt REDIS_HOST=redis.
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- Kafka (Spring Cloud Stream: UserCreatedEvent, OrderCreatedEvent) -----
# [mặc định localhost:9092]. Chạy full trong Docker thì đặt KAFKA_BROKERS=kafka:29092.
KAFKA_BROKERS=localhost:9092

# ----- Eureka (service discovery) -----
# [mặc định http://localhost:8761/eureka/]. Full Docker: http://eureka-server:8761/eureka/
EUREKA_URL=http://localhost:8761/eureka/

# ----- Email (auth-service gửi OTP quên mật khẩu; notification-service gửi welcome mail) -----
# BẮT BUỘC nếu muốn dùng chức năng gửi mail. Với Gmail nên dùng App Password, không phải mật khẩu thường.
MAIL_USERNAME=se184913daohonghai@gmail.com
MAIL_PASS=hpyp uhfh lfsk kuwc
# [mặc định smtp.gmail.com / 587]
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ----- Google OAuth login (auth-service) -----
# BẮT BUỘC nếu dùng đăng nhập bằng Google (endpoint /api/v1/auth/login/google).
GOOGLE_CLIENT_ID=123
