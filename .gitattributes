# Chuẩn hoá line ending khi checkout/commit.
# Lý do: repo phát triển trên Windows nhưng CI/EC2 chạy Linux. File YAML/shell dính CRLF
# hoặc BOM sẽ làm YAML parser báo "control characters are not allowed" và làm mvnw/*.sh
# không chạy được trên Linux.

* text=auto eol=lf

*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.json      text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
Dockerfile  text eol=lf
mvnw        text eol=lf

# Script Windows PHẢI giữ CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
mvnw.cmd    text eol=crlf

# Binary: không đụng vào
*.jar       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
