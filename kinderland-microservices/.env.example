# =============================================================================
# Mẫu biến môi trường cho Kinderland Microservices.
# Copy file này thành `.env` (cùng thư mục chạy service) rồi điền giá trị thật.
# Mỗi service tự nạp qua: spring.config.import=optional:file:.env[.properties]
# (KHÔNG commit file .env thật — đã có trong .gitignore.)
# =============================================================================

# ---- JWT (auth-service ký, api-gateway verify — PHẢI trùng secret) ----
# Secret >= 32 ký tự (HS256).
JWT_SECRET=ThisIsADevSecretChangeMeToALongRandomValue123456
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ---- PostgreSQL (auth/product/order) ----
DB_USERNAME=postgres
DB_PASSWORD=123456

# ---- Kafka (auth publish, product/notification consume) ----
# Chạy service trên host: localhost:9092 | chạy trong Docker: kafka:29092
KAFKA_BROKERS=localhost:9092

# ---- Eureka ----
EUREKA_URL=http://localhost:8761/eureka/

# ---- Email (auth gửi OTP, notification gửi welcome) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASS=your-app-password

# ---- Google OAuth (auth-service) ----
GOOGLE_CLIENT_ID=your-google-client-id
